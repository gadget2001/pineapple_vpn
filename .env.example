PROJECT_NAME=Pineapple VPN
DOMAIN=pineapple.ambot24.ru
APP_ENV=production

# Backend
SECRET_KEY=change_me
JWT_SECRET=change_me
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
LEGAL_DOCS_VERSION=2026-03-15
ALLOWED_ORIGINS=https://pineapple.ambot24.ru,https://t.me
FRONTEND_URL=https://pineapple.ambot24.ru
API_BASE_URL=https://pineapple.ambot24.ru/api
RATE_LIMIT_PER_MINUTE=120

# Subscription pricing (RUB)
SUBSCRIPTION_PRICE_WEEK_RUB=99
SUBSCRIPTION_PRICE_MONTH_RUB=199

DB_HOST=example.db.host
DB_PORT=5432
DB_NAME=pineapple_vpn
DB_USER=pineapple
DB_PASSWORD=change_me
DB_SSLMODE=require

REDIS_URL=redis://redis:16379/0
LOG_RETENTION_DAYS=30
SCHED_TZ=Europe/Moscow

# Telegram
BOT_TOKEN=change_me
ADMIN_CHAT_ID=123456789
TELEGRAM_MINIAPP_URL=https://pineapple.ambot24.ru
TELEGRAM_BOT_USERNAME=pineapple_vpn_bot
TELEGRAM_DEBUG_AUTH=false

# YooKassa
YOOKASSA_SHOP_ID=change_me
YOOKASSA_SECRET_KEY=change_me
YOOKASSA_WEBHOOK_SECRET=change_me
# Optional IP allowlist for webhook source validation (comma-separated CIDR/IP), use * to disable
YOOKASSA_WEBHOOK_IPS=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11,77.75.156.35,77.75.154.128/25,2a02:5180::/32
# 54-FZ receipts metadata fields (kept for compatibility in payment records)
YOOKASSA_RECEIPT_DESCRIPTION=РџРѕРїРѕР»РЅРµРЅРёРµ Р±Р°Р»Р°РЅСЃР° Pineapple VPN
YOOKASSA_RECEIPT_VAT_CODE=1
YOOKASSA_RECEIPT_PAYMENT_MODE=full_prepayment
YOOKASSA_RECEIPT_PAYMENT_SUBJECT=service

# VPN Panel (Marzban)
PANEL_URL=http://panel:19090
PANEL_TOKEN=change_me
PANEL_USERNAME=admin
PANEL_PASSWORD=change_me
PANEL_INBOUND_NAME=VLESS TCP REALITY
VPN_LIMIT_MBPS=50
VPN_MAX_CONNECTIONS=2
VPN_DAILY_DATA_LIMIT_GB=40
VPN_DAILY_LIMIT_ALERTS_ENABLED=true
VPN_CONNECTION_NAME_TEMPLATE=рџЌЌ Pineapple VPN ({username})

# Xray access log ingestion
VPN_ACCESS_LOG_ENABLED=true
VPN_ACCESS_LOG_PATH=/var/log/xray/access.log
VPN_ACCESS_LOG_CURSOR_KEY=xray_access_log
VPN_ACCESS_LOG_MAX_LINES_PER_RUN=5000
VPN_ACCESS_LOG_POLL_SECONDS=120
VPN_CONNECTION_LOG_RETENTION_DAYS=30`r`nVPN_ACCESS_LOG_HOST_DIR=/var/log/xray

# Security
WEBHOOK_BASE_URL=https://pineapple.ambot24.ru
WEBHOOK_PATH=/api/payments/webhook

# Marzban
MARZBAN_DB_URL=postgresql://user:pass@host:5432/marzban
